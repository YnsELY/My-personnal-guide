{
  "expo": {
    "name": "Nefsy",
    "slug": "guide-omra",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "guideomra",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marwann7.guideomra",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.marwann7.guideomra"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#09090b",
          "dark": {
            "backgroundColor": "#09090b"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autorisez l'accès à vos médias pour envoyer les preuves vidéo Omra Badal.",
          "cameraPermission": "Autorisez l'accès à la caméra pour capturer les preuves vidéo Omra Badal."
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#b39164",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "effe5339-df17-4830-a662-bbf8372b3b76"
      }
    }
  }
}
